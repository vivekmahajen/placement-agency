# Database (SQLite for development; swap for Postgres in production)
DATABASE_URL="file:./dev.db"

# JWT Secret – must be at least 32 characters, keep secret!
JWT_SECRET="urgentmail-jwt-secret-must-be-32chars-min-change-in-production"

# Google OAuth (for Gmail read-only access)
# Create credentials at https://console.cloud.google.com → APIs → Gmail API
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_REDIRECT_URI="http://localhost:3000/api/gmail/callback"

# Twilio (for SMS delivery)
# Create account at https://www.twilio.com
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="your-twilio-auth-token"
TWILIO_PHONE_NUMBER="+15550000000"

# Stripe (for subscription payments)
# Keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Cron secret – sent as Bearer token to protect /api/cron/daily-summary
# Schedule this endpoint to run daily at 6 AM PST using Vercel Cron, GitHub Actions, etc.
CRON_SECRET="your-strong-random-cron-secret"

# Admin user – first user registered with this email gets ADMIN role
ADMIN_EMAIL="admin@yourdomain.com"

# App URL (used for Stripe redirect URLs)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
